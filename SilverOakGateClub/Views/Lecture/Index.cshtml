@model SilverOakGateClub.ViewModel.LectureListViewModel
@{
    ViewData["Title"] = "Lectures";
}

<div class="page-header d-flex justify-content-between align-items-end mb-5">
    <div>
        <h1 class="display-5 fw-bold mb-2" style="background:var(--primary-gradient);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">Video lectures</h1>
        <p class="text-muted mb-0">Explore curated content for <span class="badge-primary">@Model.BranchName</span></p>
    </div>
</div>

<!-- Subject Filter -->
@if (Model.Subjects.Count > 0)
{
    <div class="d-flex gap-2 flex-wrap mb-5 pb-3" style="border-bottom:1px solid var(--border-color);">
        <a href="@Url.Action("Index", "Lecture")" 
           class="btn-filter @(Model.SelectedSubject == null ? "active" : "")">
            <i class="bi bi-grid-fill me-2"></i> All Topics
        </a>
        @foreach (var subject in Model.Subjects)
        {
            var isActive = Model.SelectedSubject == subject;
            <a href="@Url.Action("Index", "Lecture", new { subject = subject })"
               class="btn-filter @(isActive ? "active" : "")">
                @subject
            </a>
        }
    </div>
}

@if (Model.Lectures.Count > 0)
{
    <div class="row g-4 mb-5">
        @foreach (var lecture in Model.Lectures)
        {
            <div class="col-md-6 col-lg-4 animate-in">
                <a href="@Url.Action("Watch", "Lecture", new { id = lecture.Id })" class="lecture-card-link">
                    <div class="lecture-card">
                        <div class="lecture-thumbnail-wrapper">
                            @if (!string.IsNullOrEmpty(lecture.ThumbnailUrl))
                            {
                                <img src="@lecture.ThumbnailUrl" alt="@lecture.Title" class="lecture-thumbnail" />
                            }
                            else
                            {
                                <div class="lecture-placeholder">
                                    <i class="bi bi-camera-video"></i>
                                </div>
                            }
                            <div class="lecture-play-overlay">
                                <i class="bi bi-play-fill"></i>
                            </div>
                            <div class="lecture-duration">
                                <i class="bi bi-clock me-1"></i> @lecture.DurationMinutes min
                            </div>
                        </div>

                        <div class="lecture-content">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="lecture-subject">@(string.IsNullOrEmpty(lecture.Subject) ? "General" : lecture.Subject)</span>
                                <span class="lecture-date"><i class="bi bi-calendar3 me-1"></i> @lecture.CreatedAt.ToString("MMM dd")</span>
                            </div>
                            <h5 class="lecture-title">@lecture.Title</h5>
                            <div class="lecture-stats">
                                <span><i class="bi bi-eye"></i> @lecture.ViewCount views</span>
                                <span class="ms-auto"><i class="bi bi-arrow-right-circle"></i> Watch Now</span>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
}
else
{
    <div class="empty-state py-5 my-5 text-center">
        <div class="empty-icon-wrapper mb-4">
            <i class="bi bi-play-circle" style="font-size:4rem;color:var(--primary);opacity:0.3;"></i>
        </div>
        <h3 class="fw-bold">No Lectures Available</h3>
        <p class="text-muted mx-auto" style="max-width:400px;">We're currently preparing new video content for this department. Please check back later.</p>
        <a href="@Url.Action("Index", "Dashboard")" class="btn btn-outline-custom mt-3">Back to Dashboard</a>
    </div>
}

<style>
    .btn-filter {
        padding: 8px 20px;
        border-radius: 50px;
        border: 1px solid var(--border-color);
        background: var(--bg-tertiary);
        color: var(--text-color);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
    }

    .btn-filter:hover {
        border-color: var(--primary);
        color: var(--primary);
        background: rgba(var(--primary-rgb), 0.05);
    }

    .btn-filter.active {
        background: var(--primary-gradient);
        color: white;
        border-color: transparent;
        box-shadow: 0 4px 15px rgba(var(--primary-rgb), 0.3);
    }

    .lecture-card-link {
        text-decoration: none;
        color: inherit;
        display: block;
    }

    .lecture-card {
        background: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-md);
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .lecture-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.15);
        border-color: var(--primary);
    }

    .lecture-thumbnail-wrapper {
        position: relative;
        aspect-ratio: 16/9;
        overflow: hidden;
        background: #000;
    }

    .lecture-thumbnail {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
    }

    .lecture-card:hover .lecture-thumbnail {
        transform: scale(1.05);
    }

    .lecture-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--primary-gradient);
        opacity: 0.1;
        font-size: 3rem;
        color: var(--primary);
    }

    .lecture-play-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0,0,0,0.2);
        opacity: 0;
        transition: all 0.3s ease;
    }

    .lecture-card:hover .lecture-play-overlay {
        opacity: 1;
        background: rgba(0,0,0,0.4);
    }

    .lecture-play-overlay i {
        font-size: 4rem;
        color: white;
        transform: scale(0.8);
        transition: transform 0.3s ease;
    }

    .lecture-card:hover .lecture-play-overlay i {
        transform: scale(1);
    }

    .lecture-duration {
        position: absolute;
        bottom: 12px;
        right: 12px;
        background: rgba(0,0,0,0.8);
        color: white;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 600;
        backdrop-filter: blur(4px);
    }

    .lecture-content {
        padding: 20px;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }

    .lecture-subject {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--primary);
        background: rgba(var(--primary-rgb), 0.1);
        padding: 4px 10px;
        border-radius: 4px;
    }

    .lecture-date {
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    .lecture-title {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 15px;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 3rem;
    }

    .lecture-stats {
        margin-top: auto;
        padding-top: 15px;
        border-top: 1px solid var(--border-color);
        display: flex;
        align-items: center;
        font-size: 0.85rem;
        color: var(--text-muted);
    }

    .lecture-stats span i {
        margin-right: 5px;
    }

    .lecture-stats .ms-auto i {
        transition: transform 0.3s ease;
    }

    .lecture-card:hover .lecture-stats .ms-auto i {
        transform: translateX(5px);
    }
</style>
