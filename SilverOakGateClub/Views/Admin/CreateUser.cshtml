@model SilverOakGateClub.ViewModel.CreateUserViewModel
@{
    ViewData["Title"] = "Create User";
}

<div class="page-header">
    <h1>Create User</h1>
    <p>Add a new student or admin account</p>
</div>

<div class="row justify-content-center">
    <div class="col-xl-6">
        <div class="card">
            <div class="card-body" style="padding:32px;">
                <form asp-action="CreateUser" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size:0.85rem;"></div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label">Full Name</label>
                        <input asp-for="FullName" class="form-control" placeholder="Enter full name"/>
                        <span asp-validation-for="FullName" class="text-danger" style="font-size:0.8rem;"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email</label>
                        <input asp-for="Email" class="form-control" placeholder="Enter email address"/>
                        <span asp-validation-for="Email" class="text-danger" style="font-size:0.8rem;"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Password</label>
                        <input asp-for="Password" class="form-control" placeholder="Minimum 6 characters"/>
                        <span asp-validation-for="Password" class="text-danger" style="font-size:0.8rem;"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Role" class="form-label">Role</label>
                            <select asp-for="Role" class="form-select">
                                <option value="Student">Student</option>
                                <option value="Admin">Admin</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="BranchId" class="form-label">Branch</label>
                            <select asp-for="BranchId" class="form-select">
                                <option value="">— Select Branch —</option>
                                @foreach (var b in Model.Branches)
                                {
                                    <option value="@b.Id">@b.Name</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Phone" class="form-label">Phone (Optional)</label>
                            <input asp-for="Phone" class="form-control" placeholder="Phone number"/>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="EnrollmentNumber" class="form-label">Enrollment # (Optional)</label>
                            <input asp-for="EnrollmentNumber" class="form-control" placeholder="Enrollment number"/>
                        </div>
                    </div>

                    <div class="d-flex gap-3 mt-2">
                        <button type="submit" class="btn-primary-gradient">
                            <i class="bi bi-person-plus"></i> Create User
                        </button>
                        <a href="@Url.Action("Users")" class="btn-outline-custom">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
