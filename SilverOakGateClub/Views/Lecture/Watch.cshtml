@model SilverOakGateClub.Models.Lecture
@{
    ViewData["Title"] = Model.Title;
}

<div class="mb-4">
    <a href="@Url.Action("Index", "Lecture")" class="btn-outline-custom btn-sm mb-3">
        <i class="bi bi-arrow-left"></i> Back to Lectures
    </a>
</div>

<div class="row g-4">
    <div class="col-xl-8">
        @{
            var isYouTube = Model.VideoUrl.Contains("youtube") || Model.VideoUrl.Contains("youtu.be");
            var videoId = Model.VideoUrl;
            if (videoId.Contains("v=")) videoId = videoId.Split("v=")[1].Split("&")[0];
            else if (videoId.Contains("youtu.be/")) videoId = videoId.Split("youtu.be/")[1].Split("?")[0];
        }
        <div class="video-container mb-4">
            @if (isYouTube)
            {
                <iframe src="https://www.youtube.com/embed/@videoId" allowfullscreen></iframe>
            }
            else
            {
                <video controls>
                    <source src="@Model.VideoUrl"/>
                    Your browser does not support the video tag.
                </video>
            }
        </div>

        <div class="card">
            <div class="card-body">
                <h4 style="font-weight:700;margin-bottom:8px;">@Model.Title</h4>
                <div class="d-flex gap-3 mb-3 flex-wrap" style="font-size:0.85rem;color:var(--text-muted);">
                    @if (!string.IsNullOrEmpty(Model.Subject))
                    {
                        <span class="badge-primary">@Model.Subject</span>
                    }
                    <span><i class="bi bi-clock me-1"></i>@Model.DurationMinutes min</span>
                    <span><i class="bi bi-eye me-1"></i>@Model.ViewCount views</span>
                    <span><i class="bi bi-calendar me-1"></i>@Model.CreatedAt.ToString("dd MMM yyyy")</span>
                </div>

                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <p style="color:var(--text-secondary);line-height:1.7;">@Model.Description</p>
                }
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        <div class="card">
            <div class="card-header">
                <h5><i class="bi bi-info-circle me-2" style="color:var(--primary);"></i>Lecture Info</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <div style="font-size:0.8rem;color:var(--text-muted);margin-bottom:4px;">Branch</div>
                    <div style="font-weight:600;">@Model.Branch?.Name</div>
                </div>
                @if (!string.IsNullOrEmpty(Model.Subject))
                {
                    <div class="mb-3">
                        <div style="font-size:0.8rem;color:var(--text-muted);margin-bottom:4px;">Subject</div>
                        <div style="font-weight:600;">@Model.Subject</div>
                    </div>
                }
                <div class="mb-3">
                    <div style="font-size:0.8rem;color:var(--text-muted);margin-bottom:4px;">Duration</div>
                    <div style="font-weight:600;">@Model.DurationMinutes minutes</div>
                </div>
                <div>
                    <div style="font-size:0.8rem;color:var(--text-muted);margin-bottom:4px;">Total Views</div>
                    <div style="font-weight:600;">@Model.ViewCount</div>
                </div>
            </div>
        </div>
    </div>
</div>
