@model SilverOakGateClub.ViewModel.CreateLectureViewModel
@{ ViewData["Title"] = "Add Lecture"; }

<div class="page-header">
    <h1>Add Lecture</h1>
    <p>Create a new lecture for your assigned departments</p>
</div>

<div class="card" style="max-width:700px;">
    <div class="card-body">
        <form asp-action="CreateLecture" asp-controller="Teacher" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label">Title *</label>
                <input asp-for="Title" class="form-control" placeholder="Enter lecture title" />
                <span asp-validation-for="Title" class="text-danger" style="font-size:0.8rem;"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Brief description..."></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label">Video URL *</label>
                <input asp-for="VideoUrl" class="form-control" placeholder="https://youtube.com/..." />
                <span asp-validation-for="VideoUrl" class="text-danger" style="font-size:0.8rem;"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Thumbnail URL</label>
                <input asp-for="ThumbnailUrl" class="form-control" placeholder="https://..." />
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <label class="form-label">Department *</label>
                    <select asp-for="BranchId" class="form-select">
                        <option value="">Select Department</option>
                        @foreach (var b in Model.Branches)
                        {
                            <option value="@b.Id">@b.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Subject</label>
                    <input asp-for="Subject" class="form-control" placeholder="e.g., Algorithms" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Duration (min)</label>
                    <input asp-for="DurationMinutes" type="number" class="form-control" />
                </div>
            </div>

            <div asp-validation-summary="All" class="text-danger mb-3" style="font-size:0.85rem;"></div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn-primary-gradient"><i class="bi bi-plus-circle"></i> Create Lecture</button>
                <a href="@Url.Action("MyContent", "Teacher")" class="btn-outline-custom">Cancel</a>
            </div>
        </form>
    </div>
</div>
