@model SilverOakGateClub.ViewModel.CreateTestViewModel
@{ ViewData["Title"] = "Create Test"; }

<div class="page-header">
    <h1>Create Test</h1>
    <p>Create a new mock test for your students</p>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="CreateTest" asp-controller="Teacher" method="post" id="createTestForm" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label">Test Title *</label>
                    <input asp-for="Title" class="form-control" placeholder="Enter test title" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Department *</label>
                    <select asp-for="BranchId" class="form-select">
                        <option value="">Select Department</option>
                        @foreach (var b in Model.Branches)
                        {
                            <option value="@b.Id">@b.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Duration (min)</label>
                    <input asp-for="DurationMinutes" type="number" class="form-control" />
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label">Description</label>
                <textarea asp-for="Description" class="form-control" rows="2"></textarea>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="form-check">
                        <input asp-for="IsPYQ" class="form-check-input" type="checkbox" id="isPYQ" />
                        <label class="form-check-label" for="isPYQ">Is PYQ?</label>
                    </div>
                </div>
                <div class="col-md-3" id="yearField" style="display:none;">
                    <label class="form-label">Year</label>
                    <input asp-for="Year" type="number" class="form-control" placeholder="2024" />
                </div>
            </div>

            <hr class="my-4" />

            <!-- Entry Method -->
            <div class="mb-4">
                <label class="form-label d-block" style="font-weight:600;">Question Entry Method</label>
                <div class="btn-group w-100" role="group">
                    <input type="radio" class="btn-check" name="entryMethod" id="methodManual" value="manual" checked>
                    <label class="btn btn-outline-primary" for="methodManual"><i class="bi bi-pencil-square me-2"></i>Manual Entry</label>

                    <input type="radio" class="btn-check" name="entryMethod" id="methodExcel" value="excel">
                    <label class="btn btn-outline-success" for="methodExcel"><i class="bi bi-file-earmark-excel me-2"></i>Excel Upload</label>
                </div>
            </div>

            <!-- Excel Upload Section -->
            <div id="excelSection" style="display:none;" class="animate-in">
                <div class="alert alert-info-soft d-flex align-items-center mb-3">
                    <i class="bi bi-info-circle-fill me-3 fs-4"></i>
                    <div>
                        <strong>Tip:</strong> Download the <a href="@Url.Action("DownloadExcelTemplate", "Teacher")" class="alert-link">Excel Template</a>, fill in your questions, and upload it here.
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="ExcelFile" class="form-label">Upload Excel File (.xlsx)</label>
                    <input asp-for="ExcelFile" type="file" class="form-control" accept=".xlsx" />
                    <p class="form-text mt-1" style="font-size:0.8rem;color:var(--text-muted);">Ensure row 1 contains headers. Parsing starts from row 2.</p>
                </div>
            </div>

            <!-- Manual Entry Section -->
            <div id="manualSection" class="animate-in">
                <h5 class="mb-3"><i class="bi bi-list-check me-2"></i>Questions</h5>
                <div id="questionsContainer"></div>

                <button type="button" class="btn-outline-custom mb-4" onclick="addQuestion()">
                    <i class="bi bi-plus-circle"></i> Add Question
                </button>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn-primary-gradient"><i class="bi bi-check-circle"></i> Create Test</button>
                <a href="@Url.Action("MyContent", "Teacher")" class="btn-outline-custom">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
let questionIndex = 0;

function addQuestion() {
    const container = document.getElementById('questionsContainer');
    const html = `
    <div class="card mb-3" id="question_${questionIndex}">
        <div class="card-header">
            <h5>Question ${questionIndex + 1}</h5>
            <button type="button" class="btn-danger-soft btn-sm" onclick="removeQuestion(${questionIndex})"><i class="bi bi-trash"></i></button>
        </div>
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label">Question Text *</label>
                <textarea name="Questions[${questionIndex}].QuestionText" class="form-control" rows="2" required></textarea>
            </div>
            <div class="row g-3 mb-3">
                <div class="col-md-6"><label class="form-label">Option A *</label><input name="Questions[${questionIndex}].OptionA" class="form-control" required /></div>
                <div class="col-md-6"><label class="form-label">Option B *</label><input name="Questions[${questionIndex}].OptionB" class="form-control" required /></div>
                <div class="col-md-6"><label class="form-label">Option C *</label><input name="Questions[${questionIndex}].OptionC" class="form-control" required /></div>
                <div class="col-md-6"><label class="form-label">Option D *</label><input name="Questions[${questionIndex}].OptionD" class="form-control" required /></div>
            </div>
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Correct Answer *</label>
                    <select name="Questions[${questionIndex}].CorrectAnswer" class="form-select" required>
                        <option value="A">A</option><option value="B">B</option><option value="C">C</option><option value="D">D</option>
                    </select>
                </div>
                <div class="col-md-4"><label class="form-label">Marks</label><input name="Questions[${questionIndex}].Marks" type="number" class="form-control" value="1" min="1" /></div>
                <div class="col-md-4"><label class="form-label">Negative Marks</label><input name="Questions[${questionIndex}].NegativeMarks" type="number" class="form-control" value="0" min="0" /></div>
            </div>
            <div class="mt-3">
                <label class="form-label">Explanation</label>
                <textarea name="Questions[${questionIndex}].Explanation" class="form-control" rows="2"></textarea>
            </div>
        </div>
    </div>`;
    container.insertAdjacentHTML('beforeend', html);
    questionIndex++;
}

function removeQuestion(idx) {
    document.getElementById(`question_${idx}`)?.remove();
}

document.getElementById('isPYQ')?.addEventListener('change', function() {
    document.getElementById('yearField').style.display = this.checked ? 'block' : 'none';
});

// Toggle between Manual and Excel
function updateEntryMethod() {
    const selectedMethod = document.querySelector('input[name="entryMethod"]:checked').value;
    const isExcel = selectedMethod === 'excel';
    document.getElementById('excelSection').style.display = isExcel ? 'block' : 'none';
    document.getElementById('manualSection').style.display = isExcel ? 'none' : 'block';
    
    // Disable hidden fields so they don't block validation
    document.querySelectorAll('#excelSection input, #excelSection select, #excelSection textarea').forEach(el => {
        el.disabled = !isExcel;
    });
    document.querySelectorAll('#manualSection input, #manualSection select, #manualSection textarea').forEach(el => {
        el.disabled = isExcel;
    });
}

document.querySelectorAll('input[name="entryMethod"]').forEach(radio => {
    radio.addEventListener('change', updateEntryMethod);
});

// Initialize state on load
updateEntryMethod();

document.getElementById('createTestForm').addEventListener('submit', function(e) {
    console.log('Form submission triggered!');
    const method = document.querySelector('input[name="entryMethod"]:checked').value;
    console.log('Entry Method:', method);
});
</script>
}
