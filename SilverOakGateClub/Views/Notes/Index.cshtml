@model SilverOakGateClub.ViewModel.NotesListViewModel
@{
    ViewData["Title"] = "Notes";
}

<div class="page-header">
    <h1>Study Notes</h1>
    <p>@Model.BranchName — Download study materials and resources</p>
</div>

<!-- Subject Filter -->
@if (Model.Subjects.Count > 0)
{
    <div class="d-flex gap-2 flex-wrap mb-4">
        <a href="@Url.Action("Index", "Notes")" class="btn-outline-custom btn-sm"
           style="@(Model.SelectedSubject == null ? "background:var(--primary-gradient);color:white;border-color:transparent;" : "")">
            All
        </a>
        @foreach (var subject in Model.Subjects)
        {
            var isActive = Model.SelectedSubject == subject;
            <a href="@Url.Action("Index", "Notes", new { subject = subject })"
               class="btn-outline-custom btn-sm"
               style="@(isActive ? "background:var(--primary-gradient);color:white;border-color:transparent;" : "")">
                @subject
            </a>
        }
    </div>
}

@if (Model.NotesList.Count > 0)
{
    <div class="row g-4">
        @foreach (var notes in Model.NotesList)
        {
            <div class="col-md-6 col-xl-4 animate-in">
                <div class="test-card">
                    <div class="d-flex align-items-start gap-3 mb-3">
                        <div style="width:48px;height:48px;border-radius:var(--radius-sm);background:rgba(239,68,68,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                            <i class="bi bi-file-earmark-pdf" style="font-size:1.3rem;color:var(--danger);"></i>
                        </div>
                        <div style="flex:1;min-width:0;">
                            <h5 style="font-weight:600;font-size:0.95rem;margin:0;">@notes.Title</h5>
                            @if (!string.IsNullOrEmpty(notes.Subject))
                            {
                                <span class="badge-primary" style="font-size:0.7rem;">@notes.Subject</span>
                            }
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(notes.Description))
                    {
                        <p style="font-size:0.85rem;color:var(--text-muted);margin-bottom:12px;">
                            @notes.Description.Substring(0, Math.Min(notes.Description.Length, 80))@(notes.Description.Length > 80 ? "..." : "")
                        </p>
                    }

                    <!-- Rating -->
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <div class="star-rating" id="rating-@notes.Id">
                            @for (int i = 1; i <= 5; i++)
                            {
                                var starClass = i <= Math.Round(notes.AverageRating) ? "active" : "";
                                <span class="star @starClass" data-value="@i" onclick="rateNotes(@notes.Id, @i)">
                                    <i class="bi bi-star-fill"></i>
                                </span>
                            }
                        </div>
                        <span style="font-size:0.8rem;color:var(--text-muted);">
                            @notes.AverageRating.ToString("F1") (@notes.RatingCount)
                        </span>
                    </div>

                    <div class="test-meta" style="margin:0;">
                        <span><i class="bi bi-download"></i> @notes.DownloadCount downloads</span>
                        <span><i class="bi bi-hdd"></i> @((notes.FileSizeBytes / 1024.0 / 1024.0).ToString("F1")) MB</span>
                    </div>

                    <div class="mt-3 pt-3" style="border-top:1px solid var(--border-color);">
                        <a href="@Url.Action("Download", "Notes", new { id = notes.Id })" class="btn-primary-gradient btn-sm">
                            <i class="bi bi-download"></i> Download
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="empty-state">
        <i class="bi bi-file-earmark-text d-block"></i>
        <h5>No notes available</h5>
        <p>Check back later for study materials</p>
    </div>
}

@section Scripts {
    <script>
        async function rateNotes(notesId, rating) {
            await fetch(`/Notes/Rate?id=${notesId}&rating=${rating}`, {
                method: 'POST',
                headers: { 'RequestVerificationToken': '' }
            });

            // Update UI
            const ratingEl = document.getElementById('rating-' + notesId);
            ratingEl.querySelectorAll('.star').forEach(star => {
                const val = parseInt(star.dataset.value);
                star.classList.toggle('active', val <= rating);
            });
        }
    </script>
}
