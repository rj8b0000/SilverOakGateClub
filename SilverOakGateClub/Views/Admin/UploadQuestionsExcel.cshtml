@model SilverOakGateClub.ViewModel.ExcelUploadViewModel
@{ ViewData["Title"] = "Upload Questions via Excel"; }

<div class="page-header">
    <h1>Import Questions via Excel</h1>
    <p>Upload questions for: <strong>@Model.TestTitle</strong></p>
</div>

<div class="row g-4">
    <div class="col-md-7">
        <div class="card">
            <div class="card-header"><h5><i class="bi bi-file-earmark-excel me-2"></i>Upload Excel File</h5></div>
            <div class="card-body">
                <form asp-action="UploadQuestionsExcel" asp-route-id="@Model.TestId" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div class="upload-zone mb-3" onclick="document.getElementById('excelFile').click()">
                        <i class="bi bi-cloud-arrow-up"></i>
                        <p>Click to select an <strong>.xlsx</strong> file</p>
                        <p style="font-size:0.8rem; color:var(--text-muted);">or drag and drop</p>
                    </div>
                    <input type="file" name="file" id="excelFile" accept=".xlsx" class="form-control mb-3" />

                    <button type="submit" class="btn-primary-gradient"><i class="bi bi-upload"></i> Upload & Import</button>
                </form>

                @if (Model.Errors.Count > 0)
                {
                    <div class="error-list">
                        <strong style="color:var(--danger);"><i class="bi bi-exclamation-triangle me-1"></i>Errors found:</strong>
                        <ul class="mt-2 mb-0 ps-3">
                            @foreach (var error in Model.Errors)
                            {
                                <li>@error</li>
                            }
                        </ul>
                    </div>
                }

                @if (Model.SuccessCount > 0)
                {
                    <div class="mt-3 p-3" style="background:rgba(46,125,50,0.08); border:1px solid rgba(46,125,50,0.2); border-radius:var(--radius-sm);">
                        <i class="bi bi-check-circle-fill" style="color:var(--success);"></i>
                        <strong>@Model.SuccessCount questions imported successfully!</strong>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-5">
        <div class="card">
            <div class="card-header"><h5><i class="bi bi-download me-2"></i>Download Template</h5></div>
            <div class="card-body">
                <p style="font-size:0.9rem; color:var(--text-secondary);">Download the sample Excel template to see the required format.</p>

                <a href="@Url.Action("DownloadExcelTemplate", "Admin")" class="btn-success-soft mb-3" style="display:inline-flex; align-items:center; gap:6px; padding:8px 16px; text-decoration:none;">
                    <i class="bi bi-file-earmark-excel"></i> Download Template
                </a>

                <hr />
                <h6 class="mb-2" style="font-size:0.85rem;">Required Columns:</h6>
                <table class="table-modern" style="font-size:0.8rem;">
                    <thead><tr><th>Column</th><th>Required</th></tr></thead>
                    <tbody>
                        <tr><td>QuestionText</td><td><span class="badge-danger">Yes</span></td></tr>
                        <tr><td>OptionA</td><td><span class="badge-danger">Yes</span></td></tr>
                        <tr><td>OptionB</td><td><span class="badge-danger">Yes</span></td></tr>
                        <tr><td>OptionC</td><td><span class="badge-danger">Yes</span></td></tr>
                        <tr><td>OptionD</td><td><span class="badge-danger">Yes</span></td></tr>
                        <tr><td>CorrectAnswer (A/B/C/D)</td><td><span class="badge-danger">Yes</span></td></tr>
                        <tr><td>Marks</td><td><span class="badge-danger">Yes</span></td></tr>
                        <tr><td>Department</td><td><span class="badge-secondary">Optional</span></td></tr>
                        <tr><td>Subject</td><td><span class="badge-secondary">Optional</span></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a href="@Url.Action("ViewTest", "Admin", new { id = Model.TestId })" class="btn-outline-custom"><i class="bi bi-arrow-left"></i> Back to Test</a>
</div>
