@model SilverOakGateClub.ViewModel.EditTeacherViewModel
@{ ViewData["Title"] = "Edit Teacher"; }

<div class="page-header"><h1>Edit Teacher</h1><p>Update teacher info and department assignments</p></div>

<div class="card" style="max-width:700px;">
    <div class="card-body">
        <form asp-action="EditTeacher" asp-controller="Admin" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="TeacherId" />

            <div class="mb-3"><label class="form-label">Full Name</label><input asp-for="FullName" class="form-control" /></div>
            <div class="mb-3"><label class="form-label">Email</label><input asp-for="Email" class="form-control" readonly /></div>
            <div class="mb-3"><label class="form-label">Phone</label><input asp-for="Phone" class="form-control" /></div>
            <div class="mb-3 form-check"><input asp-for="IsActive" class="form-check-input" type="checkbox" /><label class="form-check-label">Active</label></div>

            <div class="mb-3">
                <label class="form-label">Assigned Departments</label>
                <div class="multi-select-container">
                    @foreach (var dept in Model.AllDepartments)
                    {
                        <label class="multi-select-item">
                            <input type="checkbox" name="SelectedDepartmentIds" value="@dept.Id"
                                   @(Model.SelectedDepartmentIds.Contains(dept.Id) ? "checked" : "") />
                            <span>@dept.Name</span>
                            <span class="badge-secondary ms-auto">@dept.Code</span>
                        </label>
                    }
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn-primary-gradient"><i class="bi bi-check"></i> Save Changes</button>
                <a href="@Url.Action("Teachers", "Admin")" class="btn-outline-custom">Cancel</a>
            </div>
        </form>
    </div>
</div>
