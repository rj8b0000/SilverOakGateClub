@model SilverOakGateClub.Models.MockTest
@{ ViewData["Title"] = "View Test"; }
<div class="page-header d-flex justify-content-between align-items-start">
    <div><h1>@Model.Title</h1><p>@(Model.Branch?.Name ?? "All Departments") · @Model.TotalQuestions questions · @Model.DurationMinutes min</p></div>
    <div class="d-flex gap-2">
        <a href="@Url.Action("UploadQuestionsExcel", "Admin", new { id = Model.Id })" class="btn-success-soft btn-sm"><i class="bi bi-file-earmark-excel"></i> Import Excel</a>
        <a href="@Url.Action("EditTest", "Admin", new {id = Model.Id})" class="btn-info-soft btn-sm"><i class="bi bi-pencil"></i> Edit</a>
        <a href="@Url.Action("Tests", "Admin")" class="btn-outline-custom btn-sm">Back</a>
    </div>
</div>

<div class="card">
    <div class="card-header"><h5><i class="bi bi-list-check me-2"></i>Questions (@Model.Questions.Count)</h5></div>
    <div class="card-body">
        @if (!Model.Questions.Any())
        {
            <div class="empty-state"><i class="bi bi-question-circle"></i><p>No questions added yet. <a href="@Url.Action("UploadQuestionsExcel", "Admin", new { id = Model.Id })">Import via Excel</a></p></div>
        }
        else
        {
            @foreach (var q in Model.Questions.OrderBy(q => q.OrderIndex))
            {
                <div class="question-card">
                    <div class="d-flex justify-content-between mb-2">
                        <strong>Q@(q.OrderIndex). @q.QuestionText</strong>
                        <span class="badge-primary">@q.Marks marks</span>
                    </div>
                    <div class="row g-2">
                        <div class="col-md-6"><div class="option-label @(q.CorrectAnswer == "A" ? "correct" : "")"><strong>A.</strong> @q.OptionA</div></div>
                        <div class="col-md-6"><div class="option-label @(q.CorrectAnswer == "B" ? "correct" : "")"><strong>B.</strong> @q.OptionB</div></div>
                        <div class="col-md-6"><div class="option-label @(q.CorrectAnswer == "C" ? "correct" : "")"><strong>C.</strong> @q.OptionC</div></div>
                        <div class="col-md-6"><div class="option-label @(q.CorrectAnswer == "D" ? "correct" : "")"><strong>D.</strong> @q.OptionD</div></div>
                    </div>
                    @if (!string.IsNullOrEmpty(q.Explanation))
                    {
                        <div class="mt-2" style="font-size:0.85rem; color:var(--text-secondary);"><i class="bi bi-lightbulb me-1"></i>@q.Explanation</div>
                    }
                </div>
            }
        }
    </div>
</div>
