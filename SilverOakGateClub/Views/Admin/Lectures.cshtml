@model List<SilverOakGateClub.Models.Lecture>
@{
    ViewData["Title"] = "Manage Lectures";
}

<div class="page-header d-flex justify-content-between align-items-start">
    <div>
        <h1>Manage Lectures</h1>
        <p>Add and manage video lectures</p>
    </div>
    <a href="@Url.Action("CreateLecture", "Admin")" class="btn-primary-gradient">
        <i class="bi bi-plus-circle"></i> Add Lecture
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (Model.Count > 0)
        {
            <table class="table-modern">
                <thead>
                <tr>
                    <th>Title</th>
                    <th>Branch</th>
                    <th>Subject</th>
                    <th>Duration</th>
                    <th>Views</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var l in Model)
                {
                    <tr>
                        <td style="font-weight:500;">@l.Title</td>
                        <td>@(l.Branch?.Name ?? "All Branches")</td>
                        <td>@(l.Subject ?? "—")</td>
                        <td>@l.DurationMinutes min</td>
                        <td>@l.ViewCount</td>
                        <td style="font-size:0.85rem;color:var(--text-muted);">@l.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td>
                            <div class="action-btns">
                                <a href="@Url.Action("EditLecture", "Admin", new { id = l.Id })" class="btn-info-soft btn-sm"><i class="bi bi-pencil"></i></a>
                                <form asp-action="DeleteLecture" asp-route-id="@l.Id" method="post" style="display:inline;"
                                      onsubmit="return confirm('Delete this lecture?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-danger-soft btn-sm"><i class="bi bi-trash3"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state"><i class="bi bi-play-circle d-block"></i><h5>No lectures yet</h5></div>
        }
    </div>
</div>
