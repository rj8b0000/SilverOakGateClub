@{
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var userName = User.Identity?.Name ?? "";
    var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
    var isAdmin = userRole == "Admin";
    var isTeacher = userRole == "Teacher";
    var branchName = User.FindFirst("BranchName")?.Value ?? "";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var isLoginPage = currentController == "Auth" && (currentAction == "Login" || currentAction == "AccessDenied");
    var isBranchSelection = currentController == "Auth" && currentAction == "SelectBranch";
    var initials = userName.Length > 0 ? string.Join("", userName.Split(' ').Where(w => w.Length > 0).Take(2).Select(w => w[0])).ToUpper() : "U";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <meta name="description" content="Silver Oak GATE Club - Your gateway to GATE exam preparation with mock tests, lectures, notes and more."/>
    <title>@ViewData["Title"] - Silver Oak GATE Club</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css"/>
</head>
<body>

@if (isLoginPage || isBranchSelection)
{
    @RenderBody()
}
else if (isAuthenticated)
{
    <!-- Sidebar Overlay (mobile) -->
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon"><i class="bi bi-mortarboard-fill"></i></div>
            <div>
                <div class="brand-text">GATE Club</div>
                <div class="brand-sub">Silver Oak University</div>
            </div>
        </div>

        <nav class="sidebar-nav">
            @if (isAdmin)
            {
                <div class="nav-section">
                    <div class="nav-section-title">Administration</div>
                    <a class="nav-link @(currentController == "Admin" && currentAction == "Index" ? "active" : "")" href="@Url.Action("Index", "Admin")">
                        <i class="bi bi-grid-1x2-fill"></i> Dashboard
                    </a>
                    <a class="nav-link @(currentController == "Admin" && currentAction == "Users" ? "active" : "")" href="@Url.Action("Users", "Admin")">
                        <i class="bi bi-people-fill"></i> Users
                    </a>
                    <a class="nav-link @(currentController == "Admin" && (currentAction == "Teachers" || currentAction == "CreateTeacher" || currentAction == "EditTeacher") ? "active" : "")" href="@Url.Action("Teachers", "Admin")">
                        <i class="bi bi-person-badge-fill"></i> Teachers
                    </a>
                    <a class="nav-link @(currentController == "Admin" && currentAction == "Tests" ? "active" : "")" href="@Url.Action("Tests", "Admin")">
                        <i class="bi bi-journal-check"></i> Tests
                    </a>
                    <a class="nav-link @(currentController == "Admin" && currentAction == "Lectures" ? "active" : "")" href="@Url.Action("Lectures", "Admin")">
                        <i class="bi bi-play-circle-fill"></i> Lectures
                    </a>
                    <a class="nav-link @(currentController == "Admin" && currentAction == "Notes" ? "active" : "")" href="@Url.Action("Notes", "Admin")">
                        <i class="bi bi-file-earmark-text-fill"></i> Notes
                    </a>
                    <a class="nav-link @(currentController == "Admin" && currentAction == "Announcements" ? "active" : "")" href="@Url.Action("Announcements", "Admin")">
                        <i class="bi bi-megaphone-fill"></i> Announcements
                    </a>
                </div>
            }
            else if (isTeacher)
            {
                <div class="nav-section">
                    <div class="nav-section-title">Teacher Panel</div>
                    <a class="nav-link @(currentController == "Teacher" && currentAction == "Index" ? "active" : "")" href="@Url.Action("Index", "Teacher")">
                        <i class="bi bi-grid-1x2-fill"></i> Dashboard
                    </a>
                    <a class="nav-link @(currentController == "Teacher" && currentAction == "MyContent" ? "active" : "")" href="@Url.Action("MyContent", "Teacher")">
                        <i class="bi bi-collection-fill"></i> My Content
                    </a>
                </div>
                <div class="nav-section">
                    <div class="nav-section-title">Upload</div>
                    <a class="nav-link @(currentController == "Teacher" && currentAction == "CreateNotes" ? "active" : "")" href="@Url.Action("CreateNotes", "Teacher")">
                        <i class="bi bi-file-earmark-plus-fill"></i> Upload Notes
                    </a>
                    <a class="nav-link @(currentController == "Teacher" && currentAction == "CreateLecture" ? "active" : "")" href="@Url.Action("CreateLecture", "Teacher")">
                        <i class="bi bi-camera-video-fill"></i> Add Lecture
                    </a>
                    <a class="nav-link @(currentController == "Teacher" && currentAction == "CreateTest" ? "active" : "")" href="@Url.Action("CreateTest", "Teacher")">
                        <i class="bi bi-journal-plus"></i> Create Test
                    </a>
                </div>
            }
            else
            {
                <div class="nav-section">
                    <div class="nav-section-title">Main Menu</div>
                    <a class="nav-link @(currentController == "Dashboard" ? "active" : "")" href="@Url.Action("Index", "Dashboard")">
                        <i class="bi bi-grid-1x2-fill"></i> Dashboard
                    </a>
                </div>

                <div class="nav-section">
                    <div class="nav-section-title">Exam Prep</div>
                    <a class="nav-link @(currentController == "Test" && currentAction == "Index" ? "active" : "")" href="@Url.Action("Index", "Test")">
                        <i class="bi bi-journal-check"></i> Mock Tests
                    </a>
                    <a class="nav-link @(currentController == "Test" && currentAction == "PYQ" ? "active" : "")" href="@Url.Action("PYQ", "Test")">
                        <i class="bi bi-archive-fill"></i> PYQ Papers
                    </a>
                    <a class="nav-link @(currentController == "Test" && currentAction == "History" ? "active" : "")" href="@Url.Action("History", "Test")">
                        <i class="bi bi-bar-chart-fill"></i> My Results
                    </a>
                </div>

                <div class="nav-section">
                    <div class="nav-section-title">Learning</div>
                    <a class="nav-link @(currentController == "Lecture" ? "active" : "")" href="@Url.Action("Index", "Lecture")">
                        <i class="bi bi-play-circle-fill"></i> Lectures
                    </a>
                    <a class="nav-link @(currentController == "Notes" ? "active" : "")" href="@Url.Action("Index", "Notes")">
                        <i class="bi bi-file-earmark-text-fill"></i> Notes
                    </a>
                </div>
            }
        </nav>
    </aside>

    <!-- Main Content -->
    <div class="main-content">
        <!-- Top Navbar -->
        <header class="top-navbar">
            <div class="navbar-left">
                <button class="sidebar-toggle" onclick="toggleSidebar()">
                    <i class="bi bi-list"></i>
                </button>
                <h1 class="page-title">@ViewData["Title"]</h1>
            </div>
            <div class="navbar-right">
                @if (!string.IsNullOrEmpty(branchName))
                {
                    <span class="badge-primary d-none d-md-inline">
                        <i class="bi bi-building"></i> @branchName
                    </span>
                }
                <span class="badge-info d-none d-md-inline">
                    <i class="bi bi-person"></i> @userRole
                </span>
                <div class="dropdown">
                    <div class="user-dropdown" data-bs-toggle="dropdown" aria-expanded="false">
                        <div class="user-avatar">@initials</div>
                        <div class="user-info d-none d-md-block">
                            <div class="user-name">@userName</div>
                            <div class="user-role">@userRole</div>
                        </div>
                        <i class="bi bi-chevron-down" style="font-size:0.7rem;color:var(--text-muted);"></i>
                    </div>
                    <ul class="dropdown-menu dropdown-menu-end" style="background:var(--bg-card);border:1px solid var(--border-color);">
                        <li>
                            <form asp-controller="Auth" asp-action="Logout" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item" style="color:var(--text-secondary);">
                                    <i class="bi bi-box-arrow-right me-2"></i>Logout
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </header>

        <!-- Page Content -->
        <main class="page-content">
            @RenderBody()
        </main>
    </div>
}
else
{
    @RenderBody()
}

<!-- Toast Container -->
<div class="toast-container" id="toastContainer">
    @if (TempData["Success"] != null)
    {
        <div class="toast-custom" id="successToast">
            <i class="bi bi-check-circle-fill" style="color:var(--success);font-size:1.2rem;"></i>
            <span>@TempData["Success"]</span>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="toast-custom error" id="errorToast">
            <i class="bi bi-x-circle-fill" style="color:var(--danger);font-size:1.2rem;"></i>
            <span>@TempData["Error"]</span>
        </div>
    }
</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // Sidebar toggle
    function toggleSidebar() {
        document.getElementById('sidebar')?.classList.toggle('show');
        document.getElementById('sidebarOverlay')?.classList.toggle('show');
    }

    // Auto-dismiss toasts
    document.querySelectorAll('.toast-custom').forEach(toast => {
        setTimeout(() => {
            toast.style.animation = 'slideInRight 0.3s ease reverse forwards';
            setTimeout(() => toast.remove(), 300);
        }, 4000);
    });
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>