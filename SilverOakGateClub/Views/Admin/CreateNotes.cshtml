@model SilverOakGateClub.ViewModel.CreateNotesViewModel
@{
    ViewData["Title"] = "Upload Notes";
}

<div class="page-header">
    <h1>Upload Notes</h1>
    <p>Add study materials for students</p>
</div>

<div class="row justify-content-center">
    <div class="col-xl-6">
        <div class="card">
            <div class="card-body" style="padding:32px;">
                <form asp-action="CreateNotes" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">Title</label>
                        <input asp-for="Title" class="form-control" placeholder="Notes title"/>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Brief description"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="BranchId" class="form-label">Branch</label>
                            <select asp-for="BranchId" class="form-select">
                                <option value="">— Select —</option>
                                @foreach (var b in Model.Branches)
                                {
                                    <option value="@b.Id">@b.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Subject" class="form-label">Subject</label>
                            <input asp-for="Subject" class="form-control" placeholder="e.g., Operating Systems"/>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Upload File</label>
                        <div class="file-upload-area" onclick="document.getElementById('fileInput').click();">
                            <i class="bi bi-cloud-arrow-up d-block"></i>
                            <p style="color:var(--text-secondary);margin:0;">Click to upload PDF, DOC, DOCX, PPT</p>
                            <p style="font-size:0.8rem;color:var(--text-muted);margin:4px 0 0;">Max file size: 50MB</p>
                        </div>
                        <input type="file" id="fileInput" name="file" accept=".pdf,.doc,.docx,.ppt,.pptx" style="display:none;" onchange="showFileName(this)"/>
                        <div id="fileName" style="margin-top:8px;font-size:0.85rem;color:var(--primary-light);"></div>
                    </div>

                    <div class="d-flex gap-3">
                        <button type="submit" class="btn-primary-gradient"><i class="bi bi-upload"></i> Upload Notes</button>
                        <a href="@Url.Action("Notes")" class="btn-outline-custom">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showFileName(input) {
            if (input.files && input.files[0]) {
                document.getElementById('fileName').textContent = '📄 ' + input.files[0].name;
            }
        }
    </script>
}
