@model List<SilverOakGateClub.Models.MockTest>
@{
    ViewData["Title"] = "Manage Tests";
}

<div class="page-header d-flex justify-content-between align-items-start">
    <div>
        <h1>Manage Tests</h1>
        <p>Create and manage mock tests and PYQ papers</p>
    </div>
    <a href="@Url.Action("CreateTest", "Admin")" class="btn-primary-gradient">
        <i class="bi bi-plus-circle"></i> Create Test
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (Model.Count > 0)
        {
            <table class="table-modern">
                <thead>
                <tr>
                    <th>Title</th>
                    <th>Branch</th>
                    <th>Type</th>
                    <th>Duration</th>
                    <th>Questions</th>
                    <th>Marks</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var t in Model)
                {
                    <tr>
                        <td style="font-weight:500;">@t.Title</td>
                        <td>@(t.Branch?.Name ?? "All Branches")</td>
                        <td><span class="@(t.IsPYQ ? "badge-info" : "badge-primary")">@(t.IsPYQ ? "PYQ" : "Mock")</span></td>
                        <td>@t.DurationMinutes min</td>
                        <td>@t.TotalQuestions</td>
                        <td>@t.TotalMarks</td>
                        <td><span class="@(t.IsActive ? "badge-success" : "badge-warning")">@(t.IsActive ? "Active" : "Inactive")</span></td>
                        <td style="font-size:0.85rem;color:var(--text-muted);">@t.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td>
                            <div class="action-btns">
                                <a href="@Url.Action("ViewTest", "Admin", new { id = t.Id })" class="btn-info-soft btn-sm"><i class="bi bi-eye"></i></a>
                                <a href="@Url.Action("EditTest", "Admin", new { id = t.Id })" class="btn-warning-soft btn-sm" style="background:rgba(237,108,2,0.08);color:var(--warning);border:1px solid rgba(237,108,2,0.2);"><i class="bi bi-pencil"></i></a>
                                <a href="@Url.Action("UploadQuestionsExcel", "Admin", new { id = t.Id })" class="btn-success-soft btn-sm"><i class="bi bi-file-earmark-excel"></i></a>
                                <form asp-action="DeleteTest" asp-route-id="@t.Id" method="post" style="display:inline;"
                                      onsubmit="return confirm('Delete this test and all its questions?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-danger-soft btn-sm"><i class="bi bi-trash3"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-journal-x d-block"></i>
                <h5>No tests created yet</h5>
            </div>
        }
    </div>
</div>
