@model SilverOakGateClub.ViewModel.BranchSelectionViewModel
@{
    ViewData["Title"] = "Select Branch";
    Layout = "_Layout";
}

<div class="login-page">
    <div style="max-width:900px;width:100%;padding:20px;position:relative;z-index:1;">
        <div class="text-center mb-5">
            <div class="login-logo">
                <div class="logo-icon" style="display:inline-flex;"><i class="bi bi-mortarboard-fill"></i></div>
            </div>
            <h2 class="mt-3" style="font-size:1.8rem;font-weight:700;">Choose Your Branch</h2>
            <p style="color:var(--text-muted);font-size:0.95rem;">Select your GATE exam branch to personalize your experience</p>
        </div>

        <div class="branch-grid">
            @{
                var icons = new[] { "bi-cpu", "bi-broadcast", "bi-lightning", "bi-gear", "bi-building", "bi-speedometer2" };
                var idx = 0;
            }
            @foreach (var branch in Model.Branches)
            {
                var icon = idx < icons.Length ? icons[idx] : "bi-book";
                var isSelected = Model.SelectedBranchId == branch.Id;
                <form asp-action="SelectBranch" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="branchId" value="@branch.Id"/>
                    <button type="submit" class="branch-card @(isSelected ? "selected" : "")" style="border:2px solid var(--border-color);width:100;">
                        <div class="branch-icon"><i class="bi @icon"></i></div>
                        <h5>@branch.Name</h5>
                        <p>@branch.Code</p>
                    </button>
                </form>
                idx++;
            }
        </div>
    </div>
</div>
