@model List<SilverOakGateClub.Models.User>
@{ ViewData["Title"] = "Teacher Management"; }

<div class="page-header d-flex justify-content-between align-items-start">
    <div><h1>Teacher Management</h1><p>Create, manage, and assign departments to teachers</p></div>
    <a href="@Url.Action("CreateTeacher", "Admin")" class="btn-primary-gradient"><i class="bi bi-plus-circle"></i> Create Teacher</a>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (Model.Count == 0)
        {
            <div class="empty-state"><i class="bi bi-person-badge"></i><p>No teachers created yet</p></div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table-modern">
                    <thead><tr><th>Name</th><th>Email</th><th>Phone</th><th>Departments</th><th>Status</th><th>Actions</th></tr></thead>
                    <tbody>
                    @foreach (var t in Model)
                    {
                        <tr>
                            <td><strong>@t.FullName</strong></td>
                            <td>@t.Email</td>
                            <td>@(t.Phone ?? "—")</td>
                            <td>
                                @if (t.TeacherDepartments.Any())
                                {
                                    @foreach (var td in t.TeacherDepartments)
                                    {
                                        <span class="badge-primary me-1">@td.Department.Name</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted-custom">None assigned</span>
                                }
                            </td>
                            <td>
                                @if (t.IsActive) { <span class="badge-success">Active</span> } else { <span class="badge-danger">Inactive</span> }
                            </td>
                            <td>
                                <div class="action-btns">
                                    <a href="@Url.Action("EditTeacher", "Admin", new { id = t.Id })" class="btn-info-soft btn-sm"><i class="bi bi-pencil"></i> Edit</a>
                                    <form asp-action="DeactivateTeacher" asp-route-id="@t.Id" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-danger-soft btn-sm" onclick="return confirm('Deactivate this teacher?')"><i class="bi bi-slash-circle"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
