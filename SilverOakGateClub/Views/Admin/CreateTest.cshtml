@model SilverOakGateClub.ViewModel.CreateTestViewModel
@{
    ViewData["Title"] = "Create Test";
}

<div class="page-header">
    <h1>Create Test</h1>
    <p>Add a new mock test or PYQ paper with questions</p>
</div>

<div class="row justify-content-center">
    <div class="col-xl-8">
        <div class="card mb-4">
            <div class="card-header">
                <h5><i class="bi bi-info-circle me-2" style="color:var(--primary);"></i>Test Details</h5>
            </div>
            <div class="card-body" style="padding:28px;">
                <form asp-action="CreateTest" method="post" id="createTestForm">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">Test Title</label>
                        <input asp-for="Title" class="form-control" placeholder="e.g., GATE CS 2025 Mock Test 1"/>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Brief description of the test"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="BranchId" class="form-label">Branch</label>
                            <select asp-for="BranchId" class="form-select">
                                <option value="">— All Branches —</option>
                                @foreach (var b in Model.Branches)
                                {
                                    <option value="@b.Id">@b.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="DurationMinutes" class="form-label">Duration (minutes)</label>
                            <input asp-for="DurationMinutes" class="form-control" type="number"/>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="form-check mt-4">
                                <input asp-for="IsPYQ" class="form-check-input" style="background-color:var(--bg-tertiary);border-color:var(--border-color);"/>
                                <label asp-for="IsPYQ" class="form-check-label" style="color:var(--text-secondary);">This is a PYQ Paper</label>
                            </div>
                            <div class="mt-2" id="yearField" style="display:none;">
                                <label asp-for="Year" class="form-label">Year</label>
                                <input asp-for="Year" class="form-control" type="number" placeholder="e.g., 2024"/>
                            </div>
                        </div>
                    </div>

                    <!-- Questions -->
                    <hr style="border-color:var(--border-color);margin:24px 0;"/>
                    <h5 style="font-weight:600;margin-bottom:16px;"><i class="bi bi-list-check me-2" style="color:var(--primary);"></i>Questions</h5>

                    <div id="questionsContainer"></div>

                    <button type="button" class="btn-outline-custom mt-3" onclick="addQuestion()">
                        <i class="bi bi-plus-circle"></i> Add Question
                    </button>

                    <hr style="border-color:var(--border-color);margin:24px 0;"/>

                    <div class="d-flex gap-3">
                        <button type="submit" class="btn-primary-gradient">
                            <i class="bi bi-check2-circle"></i> Create Test
                        </button>
                        <a href="@Url.Action("Tests")" class="btn-outline-custom">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let questionCount = 0;

        document.getElementById('IsPYQ')?.addEventListener('change', function () {
            document.getElementById('yearField').style.display = this.checked ? 'block' : 'none';
        });

        function addQuestion() {
            const idx = questionCount++;
            const html = `
                <div class="question-card" id="q-${idx}">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="question-number">${idx + 1}</span>
                        <button type="button" class="btn-danger-soft" onclick="removeQuestion(${idx})">
                            <i class="bi bi-trash3"></i> Remove
                        </button>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Question Text</label>
                        <textarea name="Questions[${idx}].QuestionText" class="form-control" rows="2" required placeholder="Enter the question"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Option A</label>
                            <input name="Questions[${idx}].OptionA" class="form-control" required placeholder="Option A"/>
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Option B</label>
                            <input name="Questions[${idx}].OptionB" class="form-control" required placeholder="Option B"/>
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Option C</label>
                            <input name="Questions[${idx}].OptionC" class="form-control" required placeholder="Option C"/>
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Option D</label>
                            <input name="Questions[${idx}].OptionD" class="form-control" required placeholder="Option D"/>
                        </div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-md-4 mb-2">
                            <label class="form-label">Correct Answer</label>
                            <select name="Questions[${idx}].CorrectAnswer" class="form-select" required>
                                <option value="">Select</option>
                                <option value="A">A</option>
                                <option value="B">B</option>
                                <option value="C">C</option>
                                <option value="D">D</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-2">
                            <label class="form-label">Marks</label>
                            <input name="Questions[${idx}].Marks" class="form-control" type="number" value="1" min="1" max="10"/>
                        </div>
                        <div class="col-md-4 mb-2">
                            <label class="form-label">Negative Marks</label>
                            <input name="Questions[${idx}].NegativeMarks" class="form-control" type="number" value="0" min="0" max="5"/>
                        </div>
                    </div>
                    <div class="mt-2">
                        <label class="form-label">Explanation (Optional)</label>
                        <textarea name="Questions[${idx}].Explanation" class="form-control" rows="2" placeholder="Explain the correct answer"></textarea>
                    </div>
                </div>
            `;
            document.getElementById('questionsContainer').insertAdjacentHTML('beforeend', html);
        }

        function removeQuestion(idx) {
            document.getElementById('q-' + idx)?.remove();
        }

        // Start with one question
        addQuestion();
    </script>
}
