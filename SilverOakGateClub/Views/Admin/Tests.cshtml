@model List<SilverOakGateClub.Models.MockTest>
@{
    ViewData["Title"] = "Manage Tests";
}

<div class="page-header d-flex justify-content-between align-items-start">
    <div>
        <h1>Manage Tests</h1>
        <p>Create and manage mock tests and PYQ papers</p>
    </div>
    <a href="@Url.Action("CreateTest", "Admin")" class="btn-primary-gradient">
        <i class="bi bi-plus-circle"></i> Create Test
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (Model.Count > 0)
        {
            <table class="table-modern">
                <thead>
                <tr>
                    <th>Title</th>
                    <th>Branch</th>
                    <th>Type</th>
                    <th>Duration</th>
                    <th>Questions</th>
                    <th>Marks</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var t in Model)
                {
                    <tr>
                        <td style="font-weight:500;">@t.Title</td>
                        <td>@(t.Branch?.Name ?? "All Branches")</td>
                        <td><span class="@(t.IsPYQ ? "badge-info" : "badge-primary")">@(t.IsPYQ ? "PYQ" : "Mock")</span></td>
                        <td>@t.DurationMinutes min</td>
                        <td>@t.TotalQuestions</td>
                        <td>@t.TotalMarks</td>
                        <td><span class="@(t.IsActive ? "badge-success" : "badge-warning")">@(t.IsActive ? "Active" : "Inactive")</span></td>
                        <td style="font-size:0.85rem;color:var(--text-muted);">@t.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td>
                            <form asp-action="DeleteTest" asp-route-id="@t.Id" method="post" style="display:inline;"
                                  onsubmit="return confirm('Delete this test and all its questions?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-danger-soft"><i class="bi bi-trash3"></i></button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-journal-x d-block"></i>
                <h5>No tests created yet</h5>
            </div>
        }
    </div>
</div>
