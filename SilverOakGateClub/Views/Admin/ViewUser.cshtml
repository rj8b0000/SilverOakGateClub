@model SilverOakGateClub.Models.User
@{ ViewData["Title"] = "View User"; }

<div class="page-header"><h1>User Details</h1></div>

<div class="card" style="max-width:600px;">
    <div class="card-body">
        <div class="mb-3"><label class="form-label">Full Name</label><div style="font-size:1rem; font-weight:500;">@Model.FullName</div></div>
        <div class="mb-3"><label class="form-label">Email</label><div>@Model.Email</div></div>
        <div class="mb-3"><label class="form-label">Role</label><div><span class="badge-primary">@Model.Role</span></div></div>
        <div class="mb-3"><label class="form-label">Branch</label><div>@(Model.Branch?.Name ?? "Not assigned")</div></div>
        <div class="mb-3"><label class="form-label">Phone</label><div>@(Model.Phone ?? "—")</div></div>
        <div class="mb-3"><label class="form-label">Enrollment Number</label><div>@(Model.EnrollmentNumber ?? "—")</div></div>
        <div class="mb-3"><label class="form-label">Status</label><div>@(Model.IsActive ? "Active" : "Inactive")</div></div>
        <div class="mb-3"><label class="form-label">Created</label><div>@Model.CreatedAt.ToString("dd MMM yyyy HH:mm")</div></div>
        <div class="mb-3"><label class="form-label">Last Login</label><div>@(Model.LastLoginAt?.ToString("dd MMM yyyy HH:mm") ?? "Never")</div></div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("EditUser", "Admin", new { id = Model.Id })" class="btn-primary-gradient"><i class="bi bi-pencil"></i> Edit</a>
            <a href="@Url.Action("Users", "Admin")" class="btn-outline-custom">Back</a>
        </div>
    </div>
</div>
