@model List<SilverOakGateClub.Models.User>
@{
    ViewData["Title"] = "Manage Users";
}

<div class="page-header d-flex justify-content-between align-items-start">
    <div>
        <h1>Manage Users</h1>
        <p>View, create, and manage user accounts</p>
    </div>
    <a href="@Url.Action("CreateUser", "Admin")" class="btn-primary-gradient">
        <i class="bi bi-person-plus-fill"></i> Add User
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table-modern">
            <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Branch</th>
                <th>Enrollment</th>
                <th>Status</th>
                <th>Joined</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var u in Model)
            {
                <tr>
                    <td style="font-weight:500;">@u.FullName</td>
                    <td style="color:var(--text-muted);">@u.Email</td>
                    <td><span class="@(u.Role == "Admin" ? "badge-danger" : "badge-primary")">@u.Role</span></td>
                    <td>@(u.Branch?.Name ?? "—")</td>
                    <td style="color:var(--text-muted);">@(u.EnrollmentNumber ?? "—")</td>
                    <td><span class="@(u.IsActive ? "badge-success" : "badge-warning")">@(u.IsActive ? "Active" : "Inactive")</span></td>
                    <td style="font-size:0.85rem;color:var(--text-muted);">@u.CreatedAt.ToString("dd MMM yyyy")</td>
                    <td>
                        @if (u.Role != "Admin")
                        {
                            <form asp-action="DeleteUser" asp-route-id="@u.Id" method="post" style="display:inline;"
                                  onsubmit="return confirm('Delete this user?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-danger-soft"><i class="bi bi-trash3"></i></button>
                            </form>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
