@{
    ViewData["Title"] = "Error";
}

<div class="empty-state" style="padding-top:80px;">
    <i class="bi bi-exclamation-triangle d-block" style="font-size:4rem;color:var(--danger);"></i>
    <h3 style="margin-top:16px;">Something went wrong</h3>
    <p style="color:var(--text-muted);">An error occurred while processing your request.</p>
    <a href="/" class="btn-primary-gradient mt-3"><i class="bi bi-house"></i> Go Home</a>
</div>