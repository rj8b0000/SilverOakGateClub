@model SilverOakGateClub.ViewModel.CreateAnnouncementViewModel
@{
    ViewData["Title"] = "New Announcement";
}

<div class="page-header">
    <h1>New Announcement</h1>
    <p>Post a notice to students</p>
</div>

<div class="row justify-content-center">
    <div class="col-xl-6">
        <div class="card">
            <div class="card-body" style="padding:32px;">
                <form asp-action="CreateAnnouncement" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">Title</label>
                        <input asp-for="Title" class="form-control" placeholder="Announcement title"/>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Content" class="form-label">Content</label>
                        <textarea asp-for="Content" class="form-control" rows="5" placeholder="Write your announcement..."></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Priority" class="form-label">Priority</label>
                            <select asp-for="Priority" class="form-select">
                                <option value="Low">Low</option>
                                <option value="Normal" selected>Normal</option>
                                <option value="High">High</option>
                                <option value="Urgent">Urgent</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="BranchId" class="form-label">Target Branch</label>
                            <select asp-for="BranchId" class="form-select">
                                <option value="">All Branches</option>
                                @foreach (var b in Model.Branches)
                                {
                                    <option value="@b.Id">@b.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="ExpiresAt" class="form-label">Expires At (Optional)</label>
                            <input asp-for="ExpiresAt" class="form-control" type="datetime-local"/>
                        </div>
                    </div>

                    <div class="d-flex gap-3 mt-2">
                        <button type="submit" class="btn-primary-gradient"><i class="bi bi-megaphone"></i> Post Announcement</button>
                        <a href="@Url.Action("Announcements")" class="btn-outline-custom">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
