@model SilverOakGateClub.ViewModel.CreateNotesViewModel
@{ ViewData["Title"] = "Upload Notes"; }

<div class="page-header">
    <h1>Upload Notes</h1>
    <p>Upload study materials for your assigned departments</p>
</div>

<div class="card" style="max-width:700px;">
    <div class="card-body">
        <form asp-action="CreateNotes" asp-controller="Teacher" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label">Title *</label>
                <input asp-for="Title" class="form-control" placeholder="Enter notes title" />
                <span asp-validation-for="Title" class="text-danger" style="font-size:0.8rem;"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Brief description..."></textarea>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label">Department *</label>
                    <select asp-for="BranchId" class="form-select">
                        <option value="">Select Department</option>
                        @foreach (var b in Model.Branches)
                        {
                            <option value="@b.Id">@b.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Subject</label>
                    <input asp-for="Subject" class="form-control" placeholder="e.g., Data Structures" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">File (PDF, DOC, DOCX, PPT, PPTX — max 50MB)</label>
                <input type="file" name="file" class="form-control" accept=".pdf,.doc,.docx,.ppt,.pptx" />
            </div>

            <div asp-validation-summary="All" class="text-danger mb-3" style="font-size:0.85rem;"></div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn-primary-gradient"><i class="bi bi-upload"></i> Upload Notes</button>
                <a href="@Url.Action("MyContent", "Teacher")" class="btn-outline-custom">Cancel</a>
            </div>
        </form>
    </div>
</div>
